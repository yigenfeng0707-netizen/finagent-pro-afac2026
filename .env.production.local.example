# 从 backend/.env 生成生产配置（勿提交 Git）
# 用法: copy backend\.env .env.production.local  然后编辑 DEMO_MODE=true DEBUG=false

DEBUG=false
DEMO_MODE=true
LLM_ENABLED=true
USE_REAL_DATA=true
AKSHARE_ENABLED=true
COMPLIANCE_ENABLED=true
SCHEDULER_ENABLED=true

# 以下从 backend/.env 复制:
# DASHSCOPE_API_KEY=...
# GLM_API_KEY=...
# SECRET_KEY=...  (生产环境请改为随机长字符串)
# JWT_SECRET=...
