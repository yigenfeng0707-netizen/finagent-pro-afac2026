# FinAgent Pro 生产环境变量模板
# 复制为 .env 后填入真实值：cp .env.production.example .env

# ===== 应用 =====
DEBUG=false
DEMO_MODE=true
APP_NAME=FinAgent Pro

# ===== 安全（必须修改）=====
SECRET_KEY=change-me-to-random-64-chars
JWT_SECRET=change-me-to-random-64-chars

# ===== LLM（至少配置一个）=====
LLM_PROVIDER=dashscope
LLM_ENABLED=true
DASHSCOPE_API_KEY=
GLM_API_KEY=
DEEPSEEK_API_KEY=

# ===== 数据源 =====
USE_REAL_DATA=true
AKSHARE_ENABLED=true
YFINANCE_ENABLED=true
FINNHUB_API_KEY=

# ===== 数据库 =====
DATABASE_URL=sqlite:///./data/finagent.db

# ===== 合规 =====
COMPLIANCE_ENABLED=true
SCHEDULER_ENABLED=true

# ===== 阿里云部署域名（nginx 用，可选）=====
# PUBLIC_DOMAIN=demo.finagent.example.com
