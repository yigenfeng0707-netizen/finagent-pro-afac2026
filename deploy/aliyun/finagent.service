[Unit]
Description=FinAgent Pro API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/finagent-pro/backend
EnvironmentFile=/opt/finagent-pro/.env
ExecStart=/opt/finagent-pro/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
