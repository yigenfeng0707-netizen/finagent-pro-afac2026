# ===== LLM配置 =====
# 主LLM提供商: glm / deepseek / sensenova
LLM_PROVIDER=glm
LLM_ENABLED=true

# GLM-5.1 (智谱AI，主力模型)
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://api.edgefn.net/v1
GLM_MODEL=GLM-5.1

# DeepSeek-v4-pro (深度推理，备选模型)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# SenseNova (商汤日日新，轻量快速模型)
SENSENOVA_API_KEY=your_sensenova_api_key
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
SENSENOVA_MODEL=sensenova-6.7-flash-lite

# ===== 数据源 =====
TUSHARE_TOKEN=your_tushare_token
NEWSAPI_KEY=your_newsapi_key

# ===== 数据库 =====
DATABASE_URL=sqlite:///./finagent.db
REDIS_URL=redis://localhost:6379

# ===== 应用配置 =====
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key
API_ACCESS_KEY=
API_ACCESS_ENABLED=false

# ===== 合规配置 =====
COMPLIANCE_ENABLED=true
MAX_SINGLE_STOCK_RATIO=0.10
MAX_SECTOR_RATIO=0.30
MAX_GEM_RATIO=0.20

# ===== 定时任务 =====
SCHEDULER_ENABLED=true
MORNING_REPORT_TIME=08:30
EVENING_REPORT_TIME=17:00
